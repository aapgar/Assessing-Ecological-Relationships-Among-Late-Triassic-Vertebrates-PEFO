#Each side across the diagonal of the rectangle is essentially a mirror image, so I [Dr. Tome] created a polygon to cover one side to make it less confusing

dt.triangle <- data.table(group = c(1,1,1), polygon.x = c(0,66,66), polygon.y = c(0,0,66))


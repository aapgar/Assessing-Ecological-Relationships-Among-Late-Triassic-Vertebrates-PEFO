  geom_tile(aes(fill=z_score), colour = "black") +
  scale_fill_gradient2(low = "red", mid = "white", high = "blue") +
  geom_polygon(data = dt.triangle, aes(x=polygon.x, y=polygon.y, group=group), fill = "grey50") +
  labs(title = "Significant Species Co-occurences") +

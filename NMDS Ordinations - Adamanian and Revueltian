###### NMDS Code ######
#Code utilized to generate NMDS ordinations within Apgar et al., 2025 (publication pending). 

#Input presence-absence data - will need to upload your own!
install.packages("vegan")
library(vegan)
pc=read.csv("NMDS_Practice_3_Updated_Taxonomy_No Fish.csv", header=TRUE)

#make community matrix-extract columns with abundance information
com=pc[,3:ncol(pc)]

#turn abundance frame into matrix
m_com=as.matrix(com)

set.seed(123)
nmds=metaMDS(m_com, distance="bray")
 plot(nmds)
 
 #extract NMDS scores
 data.scores=as.data.frame(scores(nmds)$sites)
 
 species.scores=as.data.frame(scores(nmds)$species)
 species.scores$species<-rownames(species.scores)
 head(species.scores)
 
 #add columns to data frame
 data.scores$Environment=pc$Environment
 head(data.scores)
 
 library(ggplot2)
 xx=ggplot(data=data.scores, aes(x=NMDS1, y=NMDS2))+
   geom_point(size=4, aes(color=Environment))+
   geom_text(data=species.scores,aes(x=NMDS1,y=NMDS2,label=species, alpha=0.5),check_overlap = TRUE, fontface="italic")+
   theme(axis.text.y=element_text(color="black",size=12,face="bold"),
   axis.text.x=element_text(color="black",face="bold",size=12),
   legend.text=element_text(size=12,face="bold",color="black"),
   axis.title.x=element_text(face="bold",size=14,color="black"),
   legend.title=element_text(size=14,color="black",face="bold"),
   panel.background=element_blank(),
   panel.border=element_rect(color="black",fill=NA,size=1.2),
   legend.key=element_blank())  +
   labs(x="NMDS1",color="Member",y="NMDS2")+
   scale_color_manual(values=c("#009E73","#E69F00"))
   orditorp(nmds,display="species",col="red",air=0.01)
plot(xx)
